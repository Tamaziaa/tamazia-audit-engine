# Dependencies
node_modules/

# Environment and local overrides (this repo is PUBLIC - secrets never land here)
.env
.env.*
*.local.*

# Tool output
reports/
*.sarif
sarif/
.jscpd-report/
.stryker-tmp/
coverage/

# catalogue compiler output (regenerated deterministically by catalogue/compile.js; never committed)
catalogue/dist/

# Scratch
scratch/
scratch.*

# Real-model proof raw call logs (U1, eval/e2e/run-real-proof.js). Full prompt/output/timing logs for
# the local reproduction proof; gitignored (may carry crawled site prose; never a key - Rule 16). The
# committed, sanitised recordings live in eval/e2e/fixtures/recorded/ instead.
eval/e2e/record/

# OS noise
.DS_Store

# supervised/manifest-store.js local run manifests (Mint Gate v0) - JSONL run records may carry crawled
# site prose; the local store is a dress-rehearsal/dev convenience, never committed (Rule 16). R2 is the
# production destination once the supervised lane graduates past v0.
.supervised-runs/
