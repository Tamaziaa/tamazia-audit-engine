# runtime/vm/.env.example - copy to .env on the VM and fill in real values. Never commit .env.
# This file itself carries no secrets, only variable names - safe for the public repo.

NEON_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=tamazia-audits
HEALTHCHECKS_PING_URL=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
RUNTIME_HOSTNAME=runtime.staging.internal
